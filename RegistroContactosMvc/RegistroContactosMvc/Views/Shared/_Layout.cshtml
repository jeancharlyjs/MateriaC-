<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Registro de Contactos</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <a class="brand" asp-controller="Contactos" asp-action="Index">Registro de Contactos</a>
        <nav>
            <a asp-controller="Contactos" asp-action="Index">Contactos</a>
            <a asp-controller="Contactos" asp-action="Create">Nuevo registro</a>
        </nav>
    </header>

    <main class="page">
        @RenderBody()
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
