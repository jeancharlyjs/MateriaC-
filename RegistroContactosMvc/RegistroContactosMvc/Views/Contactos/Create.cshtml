@model Contacto

@{
    ViewData["Title"] = "Nuevo contacto";
}

<section class="form-page">
    <div class="form-heading">
        <span class="eyebrow">Nuevo registro</span>
        <h1>Agregar contacto</h1>
        <p>Complete los datos para guardarlos en la base de datos.</p>
    </div>

    <form asp-action="Create" method="post" class="contact-form">
        <div asp-validation-summary="ModelOnly" class="validation"></div>

        <div class="field">
            <label asp-for="Nombre"></label>
            <input asp-for="Nombre" />
            <span asp-validation-for="Nombre"></span>
        </div>

        <div class="field">
            <label asp-for="Telefono"></label>
            <input asp-for="Telefono" />
            <span asp-validation-for="Telefono"></span>
        </div>

        <div class="field">
            <label asp-for="Correo"></label>
            <input asp-for="Correo" />
            <span asp-validation-for="Correo"></span>
        </div>

        <div class="field">
            <label asp-for="Ciudad"></label>
            <input asp-for="Ciudad" />
            <span asp-validation-for="Ciudad"></span>
        </div>

        <div class="field">
            <label asp-for="FechaRegistro"></label>
            <input asp-for="FechaRegistro" type="date" />
            <span asp-validation-for="FechaRegistro"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="button primary">Guardar</button>
            <a class="button secondary" asp-action="Index">Cancelar</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
