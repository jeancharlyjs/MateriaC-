@model SumaTagHelpersViewModel

<aside class="helper-summary">
    <h2>Tag Helpers utilizados</h2>
    <ul>
        <li><code>asp-for</code> enlaza controles con el modelo.</li>
        <li><code>asp-action</code> y <code>asp-controller</code> generan rutas MVC.</li>
        <li><code>asp-validation-for</code> muestra errores por campo.</li>
        <li><code>asp-items</code> llena el selector de operaciones.</li>
        <li><code>partial</code> reutiliza esta seccion como vista parcial.</li>
        <li><code>asp-append-version</code> versiona archivos estaticos.</li>
    </ul>
</aside>
