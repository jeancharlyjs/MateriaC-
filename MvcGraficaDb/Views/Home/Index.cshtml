@model VentasGraficaViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Grafica de ventas";
    var mesesJson = JsonSerializer.Serialize(Model.Meses);
    var totalesJson = JsonSerializer.Serialize(Model.Totales);
}

<section class="dashboard">
    <div class="summary">
        <div>
            <span>Total vendido</span>
            <strong>@Model.TotalGeneral.ToString("C")</strong>
        </div>
        <div>
            <span>Promedio mensual</span>
            <strong>@Model.Promedio.ToString("C")</strong>
        </div>
        <div>
            <span>Meses registrados</span>
            <strong>@Model.Meses.Count</strong>
        </div>
    </div>

    <div class="chart-panel">
        <div class="panel-heading">
            <h1>Grafica de ventas por mes</h1>
            <p>Datos cargados desde SQLite usando Entity Framework Core.</p>
        </div>
        <canvas id="ventasChart" aria-label="Grafica de ventas mensuales" role="img"></canvas>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.ventasData = {
            meses: @Html.Raw(mesesJson),
            totales: @Html.Raw(totalesJson)
        };
    </script>
    <script src="~/js/ventas-chart.js" asp-append-version="true"></script>
}
